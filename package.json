{
  "name": "hopwatch",
  "description": "SmokePing-style network latency and packet-loss monitoring. Native TypeScript, single binary, TOML configured, systemd-ready.",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.2",
  "license": "MIT",
  "author": "Kevin van Zonneveld",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kvz/hopwatch.git"
  },
  "keywords": [
    "smokeping",
    "mtr",
    "network",
    "latency",
    "packet-loss",
    "monitoring",
    "observability"
  ],
  "bin": {
    "hopwatch": "./src/bin/hopwatch.ts"
  },
  "files": [
    "src",
    "NOTICE",
    "ROADMAP.md"
  ],
  "scripts": {
    "check": "bun run format && bun run lint && bun run typecheck && bun run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "dev": "bun run --watch src/bin/hopwatch.ts daemon --config ./hopwatch.example.toml",
    "format": "biome format . --write",
    "lint": "biome check .",
    "lint:fix": "biome check --write --diagnostic-level=error .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:docker": "./scripts/docker-test.sh",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build-binary.ts"
  },
  "dependencies": {
    "clipanion": "4.0.0-rc.4",
    "execa": "9.6.1",
    "smol-toml": "^1.4.2",
    "typanion": "^3.12.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.2",
    "@types/node": "^24.10.3",
    "sharp": "^0.33.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
